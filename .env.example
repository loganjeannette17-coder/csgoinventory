# =============================================================================
# Production checklist (must be done in browser dashboards — not in this file)
# =============================================================================
#
# Vercel → Project → Settings → Environment Variables
#   Paste every variable below (same names). Enable "Production" (and Preview if needed).
#   After ANY change to NEXT_PUBLIC_* → trigger a new deployment (push or Redeploy).
#
# Supabase → Authentication → URL configuration
#   Site URL:       https://YOUR-VERCEL-DOMAIN.vercel.app   (or your custom domain)
#   Redirect URLs:  https://YOUR-VERCEL-DOMAIN.vercel.app/auth/callback
#                   http://localhost:3000/auth/callback    (optional, local dev)
#
# Stripe → Developers → Webhooks (use Live keys + Live webhook for production)
#   Endpoint URL:   https://YOUR-VERCEL-DOMAIN.vercel.app/api/stripe/webhook
#   Signing secret: copy into STRIPE_WEBHOOK_SECRET in Vercel (not from `stripe listen`)
#
# =============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# Stripe — paste full keys from Dashboard → Developers (no quotes; one line each)
# Use Test mode keys while developing (sk_test_ / pk_test_ / price IDs from Test mode products).
STRIPE_SECRET_KEY=                                 # Secret key (starts with sk_test_ or sk_live_)
STRIPE_WEBHOOK_SECRET=whsec_...                    # from `stripe listen` or dashboard webhook endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=                # Publishable key (pk_test_ or pk_live_)
STRIPE_PRICE_ID=price_...                          # one-time price ID (legacy, optional if using subscriptions)
STRIPE_SUBSCRIPTION_PRICE_ID=price_...            # recurring Pro ($4.99/mo in Stripe Dashboard)
STRIPE_BASIC_PRICE_ID=price_...                   # recurring Basic ($1.99/mo in Stripe Dashboard)
GRACE_PERIOD_DAYS=5                               # days before premium is revoked after a failed payment (1–30)
PLATFORM_FEE_BPS=300                              # platform fee in basis points: 300 = 3%, 500 = 5% (0–1000)

# Steam
STEAM_API_KEY=your-steam-api-key                   # server-only

# App (production: must be your real public origin, no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
